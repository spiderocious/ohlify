{
  "name": "mobile-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/mobile-ui/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm typecheck", "cwd": "packages/mobile-ui" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm lint", "cwd": "packages/mobile-ui" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm test", "cwd": "packages/mobile-ui" }
    }
  },
  "tags": ["scope:shared", "type:lib"],
  "implicitDependencies": ["core", "api"]
}
