# Metro (React Native's bundler, used by apps/mobile) walks node_modules
# directly and doesn't understand pnpm's strict symlinked/isolated layout —
# it expects a flat, hoisted tree like npm/yarn classic produce. This is
# Expo's own documented fix for pnpm workspaces:
# https://docs.expo.dev/guides/monorepos/#pnpm
node-linker=hoisted
