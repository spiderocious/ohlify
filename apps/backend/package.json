{
  "name": "@ohlify/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:app": "PROCESS_ROLE=app tsx watch --env-file=.env src/server.ts",
    "dev:worker": "PROCESS_ROLE=worker tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && tsc -p tsconfig.migrations.json",
    "start": "node --env-file=.env dist/server.js",
    "start:app": "PROCESS_ROLE=app node --env-file=.env dist/server.js",
    "start:worker": "PROCESS_ROLE=worker node --env-file=.env dist/server.js",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "migrate": "node-pg-migrate -m migrations --migration-file-language ts up",
    "migrate:down": "node-pg-migrate -m migrations --migration-file-language ts down"
  },
  "dependencies": {
    "agora-token": "^2.0.5",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "otplib": "^13.4.0",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2",
    "ulidx": "^2.4.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.13",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  }
}