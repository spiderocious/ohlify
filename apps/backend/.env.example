# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ohlify

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be >= 32 chars
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agora (RTC) ───────────────────────────────────────────────────────────────
AGORA_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGORA_APP_CERTIFICATE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Cloudflare R2 (Object storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=ohlify-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Push notifications ────────────────────────────────────────────────────────
# Stringified Firebase service account JSON
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# APNs
APNS_KEY=-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX

# ── Observability ─────────────────────────────────────────────────────────────
# Optional — leave blank to disable OTel export
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
