{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "exactOptionalPropertyTypes": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ohlify/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@ohlify/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@ohlify/core": [
        "../../packages/core/src/index.ts"
      ],
      "@ohlify/core/*": [
        "../../packages/core/src/*"
      ],
      "@icons": [
        "../../packages/ui/src/icons/index.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
