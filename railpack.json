{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20",
    "pnpm": "9.15.9"
  },
  "caches": {
    "pnpm-store": {
      "directory": "/root/.local/share/pnpm/store",
      "type": "shared"
    }
  },
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "pnpm config set store-dir /root/.local/share/pnpm/store",
        "pnpm install --frozen-lockfile"
      ],
      "caches": ["pnpm-store"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["pnpm nx build backend"]
    }
  },
  "deploy": {
    "startCommand": "node node_modules/node-pg-migrate/bin/node-pg-migrate.js -m apps/backend/dist/migrations --migration-file-language js up && node apps/backend/dist/server.js"
  }
}
